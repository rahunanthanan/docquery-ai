# ── Copy to .env before running: cp .env.example .env ──
# Local defaults are safe out of the box. NEVER commit a real .env.

# Database (compose uses these for the db container and backend URL)
POSTGRES_USER=docquery
POSTGRES_PASSWORD=docquery
POSTGRES_DB=docquery

# Backend
ENVIRONMENT=local
JWT_SECRET=change-me-to-a-long-random-string

# Uploads & quotas
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_BYTES=20971520
MAX_DOCUMENTS_PER_USER=25

# LLM provider: fake | openai | anthropic
# "fake" runs the entire app with NO external API keys (default for local dev)
LLM_PROVIDER=fake
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
