# ── Copy to .env before running: cp .env.example .env ──
# Local defaults are safe out of the box. NEVER commit a real .env.

# Database (compose uses these for the db container and backend URL)
POSTGRES_USER=docquery
POSTGRES_PASSWORD=docquery
POSTGRES_DB=docquery

# Backend
ENVIRONMENT=local
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:3000

# Uploads & quotas
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_BYTES=20971520
MAX_DOCUMENTS_PER_USER=25

# LLM provider: fake | openai | anthropic
# "fake" runs the entire app with NO external API keys (default for local dev)
LLM_PROVIDER=fake
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Model overrides (defaults shown). Embeddings always use OpenAI (or fake):
# Anthropic has no embeddings API, so LLM_PROVIDER=anthropic needs both keys.
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
